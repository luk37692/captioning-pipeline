# Copier en .env et adapter.  (docker compose lit .env automatiquement)

# ── Authentification de l'appli (auth HTTP basique) ──────────────────────────
APP_USER=tounum
APP_PASSWORD=change-me

# ── Tailscale ────────────────────────────────────────────────────────────────
# Clé d'auth UNIQUEMENT pour le premier enregistrement du nœud. Ensuite l'état
# persiste dans le volume tounum_ts_state : laisser vide.
TS_AUTHKEY=
TS_HOSTNAME=tounum

# ── GPU ROCm : GID des groupes de l'hôte ─────────────────────────────────────
#   getent group render | cut -d: -f3   /   getent group video | cut -d: -f3
RENDER_GID=990
VIDEO_GID=44

# ── Données / modèles montés sur /tf/notebooks (chemin ABSOLU) ───────────────
DATASET_DIR=/home/maertn/Documents/archive/cp/Dataset
